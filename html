<!DOCTYPE html>
<html>
<head>
    <title>Balloon Game</title>
    <style>
        body { 
            background: grey; 
            margin: 0;
            height: 100vh;
            overflow: hidden;
            font-family: Arial, sans-serif;
        }

        #score-text {
            color: white;
            font-size: 30px;
            padding: 20px;
            position: relative;
            z-index: 100;
        }

        .balloon {
            position: absolute;
            font-size: 60px;
            cursor: pointer;
            user-select: none;
            z-index: 10;
        }

        #victory-screen {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            display: none;
            z-index: 1000;
        }

        h1 {
            color: rgb(18, 196, 78);
            font-size: 80px;
            text-shadow: 4px 4px black;
            margin-bottom: 20px;
        }

        #next-lvl-btn {
            padding: 15px 30px;
            font-size: 25px;
            background-color: #ff0000;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
        }

        #next-lvl-btn:hover {
            background-color: #45a049;
        }
    </style>
</head>
<body>

    <div id="score-text">Points: <span id="score">0</span></div>

    <div id="victory-screen">
        <h1>VICTORY!</h1>
        <button id="next-lvl-btn" onclick="nextLevel()">NEXT LEVEL</button>
    </div>

    <script>
        let points = 0;
        let gameActive = true;

        function spawnBalloon() {
            if (!gameActive) return;

            const balloon = document.createElement("div");
            balloon.className = "balloon";
            balloon.innerHTML = "🎈";

            const x = Math.random() * (window.innerWidth - 80);
            const y = Math.random() * (window.innerHeight - 80);

            balloon.style.left = x + "px";
            balloon.style.top = y + "px";

            balloon.onclick = function() {
                if (!gameActive) return;
                points = points + 1;
                document.getElementById("score").innerHTML = points;
                this.remove();

                if (points >= 10) {
                    winGame();
                }
            };

            document.body.appendChild(balloon);
        }

        function winGame() {
            gameActive = false;
            const remaining = document.querySelectorAll('.balloon');
            remaining.forEach(b => b.remove());
            document.getElementById("victory-screen").style.display = "block";
        }

        function nextLevel() {
            document.getElementById("victory-screen").style.display = "none";
            document.body.style.background = "grey";
            points = 0;
            document.getElementById("score").innerHTML = points;
            gameActive = true;
        }

        setInterval(spawnBalloon, 800);
    </script>

</body>
</html>