<!DOCTYPE html>
<html>
<head> 
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Lobster+Two:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@100..900&family=Rubik+Storm&display=swap" rel="stylesheet">
        <title>Pop Balloon!</title>
        <style>
            body {
                background: grey;
                color: white;
                margin: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            }
            #score-text {
            color: white;
            font-size: 30px;
            padding: 20px;
            position: relative;
            z-index: 100;
        }

            .balloon {
    position: absolute;
            font-size: 60px;
            cursor: pointer;
            user-select: none;
            z-index: 10;
        }
        #victory-message {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: yellow;
            font-size: 80px;
            font-weight: bold;
            display: none;      /* Hidden until you get 10 points */
            text-shadow: 4px 4px black;
            z-index: 1000;
        }
        </style>
</head>
<body>
  <div id="score-text">Points: <span id="score">0</span></div>
    <div id="victory-message">VICTORY!</div>

   <script>
         let points = 0;
            let gameActive = true;
         function spawnBalloon() {
            if (!gameActive) return;

            const balloon = document.createElement("div");
            balloon.className = "balloon";
            balloon.innerHTML = "🎈"; 

            const x = Math.random() * (window.innerWidth - 80);
            const y = Math.random() * (window.innerHeight - 80);

            balloon.style.left = x + "px";
            balloon.style.top = y + "px";

            balloon.onclick = function() {
                if (!gameActive) return;
                points = points + 1;
                document.getElementById("score").innerHTML = points;
                this.remove();
                if (points >= 10) {
                    endGame();
                }
            };
            document.body.appendChild(balloon);
        }
        function endGame() {
            gameActive = false;
            
            const remaining = document.querySelectorAll('.balloon');
            remaining.forEach(b => b.remove());

            document.getElementById("victory-message").style.display = "block";
            document.body.style.background = "#222";
        }
        setInterval(spawnBalloon, 1250);
    </script>

</body>
</html>