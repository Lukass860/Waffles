<!DOCTYPE html>
<html>
<head> 
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Lobster+Two:ital,wght@0,400;0,700;1,400;1,700&family=Outfit:wght@100..900&family=Rubik+Storm&display=swap" rel="stylesheet">
        <title>Pop Balloon!</title>
        <style>
            body {
                background: grey;
                color: white;
                margin: 0;
            height: 100vh;
            }

            .balloon {
    position: absolute;
    z-index: 999;
    cursor: pointer;
    font-size: 50px;
    width: 60px;
    height: 60px;
}
        </style>
</head>
<body>
   <h1>Points: <span id="points">0</span></h1>

   <script>
         let points = 0;

         function spawnBalloon() {
    const balloon = document.createElement("div");
    balloon.className = "balloon";
    balloon.innerHTML = "🎈";

    const x = Math.random() * (window.innerWidth - 80);
    const y = Math.random() * (window.innerHeight - 80);

    balloon.style.left = x + "px";
    balloon.style.top = y + "px";

    balloon.onclick = function() {
        points = points + 1;
        document.getElementById("points").innerHTML = points;
        this.remove();
    };

    document.body.appendChild(balloon);
}
    setInterval(spawnBalloon, 1250);
   </script>
 </body>
</html>